{
  // Copy to ~/.openclaw/openclaw.json and replace placeholder values.
  agents: {
    defaults: {
      workspace: "/srv/openclaw/workspace-personal",
      skipBootstrap: true,
      userTimezone: "America/New_York",
      model: {
        primary: "openai/gpt-5.4",
        fallbacks: ["openai/gpt-5.4-mini"],
      },
    },
    list: [
      {
        id: "main",
        name: "Main",
        default: true,
      },
    ],
  },

  commands: {
    native: "auto",
    text: true,
    bash: false,
  },

  channels: {
    discord: {
      enabled: true,
      token: "replace-me",
      groupPolicy: "allowlist",
      guilds: {
        YOUR_SERVER_ID: {
          users: ["YOUR_USER_ID"],
          requireMention: true,
          channels: {
            YOUR_ASSISTANT_CHANNEL_ID: { allow: true },
            YOUR_TECH_BRIEF_CHANNEL_ID: { allow: true },
            YOUR_FINANCE_BRIEF_CHANNEL_ID: { allow: true },
            YOUR_RESEARCH_CHANNEL_ID: { allow: true },
            YOUR_CODING_CHANNEL_ID: { allow: true },
          },
        },
      },
      threadBindings: {
        enabled: true,
        idleHours: 24,
        maxAgeHours: 0,
        spawnSubagentSessions: true,
      },
      execApprovals: {
        enabled: "auto",
        approvers: ["YOUR_USER_ID"],
        target: "dm",
      },
    },
  },

  cron: {
    enabled: true,
    sessionRetention: "24h",
    runLog: {
      maxBytes: "2mb",
      keepLines: 2000,
    },
  },

  // After first startup on OpenClaw 2026.4.x, create the route with:
  //   openclaw agents bind --agent main --bind discord
  // This lets the installed OpenClaw version write a binding shape that matches its own schema.

  // Telegram can remain as a fallback channel until Discord is fully stable.
}
