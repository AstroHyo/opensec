{
  // Copy to ~/.openclaw/openclaw.json and replace placeholder values.
  agents: {
    defaults: {
      workspace: "/srv/openclaw/workspace-personal",
      skipBootstrap: true,
      userTimezone: "America/New_York",
      model: {
        primary: "anthropic/claude-sonnet-4-6",
        fallbacks: ["openai/gpt-5.2"],
      },
    },
    list: [
      {
        id: "coordinator",
        name: "Coordinator",
        default: true,
      },
    ],
  },

  bindings: [
    // Keep one visible front door. Hidden specialists should be spawned or delegated internally.
    {
      match: {
        channel: "discord",
        peer: { kind: "guild", id: "YOUR_SERVER_ID" },
      },
      agentId: "coordinator",
    },
  ],

  commands: {
    native: "auto",
    text: true,
    bash: false,
  },

  channels: {
    discord: {
      enabled: true,
      token: "replace-me",
      groupPolicy: "allowlist",
      guilds: {
        YOUR_SERVER_ID: {
          requireMention: true,
          channels: {
            YOUR_ASSISTANT_CHANNEL_ID: { allow: true },
            YOUR_TECH_BRIEF_CHANNEL_ID: { allow: true },
            YOUR_FINANCE_BRIEF_CHANNEL_ID: { allow: true },
            YOUR_RESEARCH_CHANNEL_ID: { allow: true },
            YOUR_CODING_CHANNEL_ID: { allow: true },
          },
        },
      },
      threadBindings: {
        enabled: true,
        idleHours: 24,
        maxAgeHours: 0,
        spawnSubagentSessions: true,
      },
      execApprovals: {
        enabled: "auto",
        approvers: ["YOUR_USER_ID"],
        target: "dm",
      },
    },
  },

  cron: {
    enabled: true,
    sessionRetention: "24h",
    runLog: {
      maxBytes: "2mb",
      keepLines: 2000,
    },
  },

  // Telegram can remain as a fallback channel until Discord is fully stable.
}
